                name: "srsname"
                orig: "srsname"
                reqd: false
                type: "`$STRING`"
              }
              {
                kind: "query"
                name: "typename"
                orig: "typename"
                reqd: false
                type: "`$STRING`"
              }
              {
                example: "2.0.0"
                kind: "query"
                name: "version"
                orig: "version"
                reqd: true
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/map/wfs"
          parts: [
            "map"
            "wfs"
          ]
          select: {
            exist: [
              "bbox"
              "count"
              "outputformat"
              "request"
              "service"
              "srsname"
              "typename"
              "version"
            ]
          }
          transform: {
