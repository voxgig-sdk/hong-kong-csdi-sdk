                type: "`$INTEGER`"
              }
              {
                kind: "query"
                name: "layer"
                orig: "layer"
                reqd: false
                type: "`$STRING`"
              }
              {
                kind: "query"
                name: "request"
                orig: "request"
                reqd: true
                type: "`$STRING`"
              }
              {
                example: "WMS"
                kind: "query"
                name: "service"
                orig: "service"
                reqd: true
                type: "`$STRING`"
              }
              {
