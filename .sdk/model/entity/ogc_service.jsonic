                orig: "bbox"
                reqd: false
                type: "`$STRING`"
              }
              {
                example: "EPSG:4326"
                kind: "query"
                name: "crs"
                orig: "crs"
                reqd: false
                type: "`$STRING`"
              }
              {
                kind: "query"
